# API Configuration
# Change this URL to your Laravel backend API URL
# Format: http://YOUR_IP:PORT
# Examples:
#   Local network: http://192.168.1.7:8000
#   Home network: http://192.168.8.135:8000
#   Remote server: http://159.198.75.110
#   With ngrok: https://your-subdomain.ngrok.io

VITE_API_BASE_URL=http://192.168.1.7:8000/api
VITE_WS_HOST=192.168.1.7
