# Copy to .env in this folder (DriverApp/) and fill in your keys.
# Restart Expo after changes: npx expo start --clear

# Mapbox (required for turn-by-turn route polylines on map screens)
# Get a token: https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_API_KEY=pk.your_mapbox_public_token_here

# Optional — match Passenger app if you add location search later
EXPO_PUBLIC_LOCATION_PROVIDER=mapbox

# Laravel Reverb (must match backend-api .env REVERB_* values)
EXPO_PUBLIC_WS_HOST=192.168.1.7
EXPO_PUBLIC_WS_PORT=8080
EXPO_PUBLIC_WS_SCHEME=http
EXPO_PUBLIC_REVERB_APP_KEY=app-key
